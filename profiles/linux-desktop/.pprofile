# vim: filetype=sh

. ~/.xdgenv

export PATH="$HOME/.local/bin:$PATH"

export EDITOR="nvim"
export VISUAL="nvim"

export BROWSER=firefox

export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

# GPU
__has_nvidia_gpu() {
  for dev in /sys/bus/pci/devices/*; do
    [ -r "$dev/vendor" ] || continue
    [ -r "$dev/class" ] || continue

    vendor="$(cat "$dev/vendor")"
    class="$(cat "$dev/class")"

    # NVIDIA vendor ID = 0x10de
    # PCI display classes start with 0x03
    if [ "$vendor" = "0x10de" ] && [ "${class#0x03}" != "$class" ]; then
      return 0
    fi
  done

  return 1
}

if __has_nvidia_gpu; then
  export DRI_PRIME=1
  export __GL_SYNC_TO_VBLANK=0
fi

# zsh
export PATH="$XDG_CONFIG_HOME/zsh/scripts/:$PATH"

# awesome-wm
export PATH="$PATH:$XDG_CONFIG_HOME/awesome/scripts/"
export PATH="$PATH:$HOME/.pub-cache/bin"

# qt
# export QT_QPA_PLATFORMTHEME=qt5ct
export QT_QPA_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=qt6ct
# export QT_STYLE_OVERRIDE=kvantum
# export QT_QPA_PLATFORMTHEME=kvantum
# export QT_AUTO_SCREEN_SCALE_FACTOR=0
# export QT_XCB_FORCE_SOFTWARE_OPENGL=0
# export QT_QUICK_BACKEND=opengl
# export QT_XCB_GL_INTEGRATION=glx

# java
export _JAVA_OPTIONS="-Dawt.useSystemAAFontSettings=on -Dswing.aatext=true -Dsun.java2d.xrender=true"

# firefox
export MOZ_ENABLE_WAYLAND=1

# minikube
export MINIKUBE_IN_STYLE=0

# libreoffice
export SAL_USE_VCLPLUGIN=qt6

# Start hyprland
if command -v uwsm >/dev/null 2>&1; then
  if uwsm check may-start; then
    exec uwsm start hyprland.desktop
  fi
else
  echo "uwsm not found. Install it to manage Wayland sessions properly." >&2
  # exec start-hyprland
fi
