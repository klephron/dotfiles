[Unit]
Description=rclone
After=network-online.target

[Service]
Type=simple
ExecStartPre=/usr/bin/mkdir -p %h/mnt/%i
ExecStart=/usr/bin/rclone mount \
            --config=%h/.config/rclone/rclone.conf \
            --vfs-cache-mode=full \
            %i: %h/mnt/%i
ExecStop=/bin/fusermount -u %h/mnt/%i
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
