#!/usr/bin/env python3

import shlex
import sys

from ansible.parsing.dataloader import DataLoader
from ansible.inventory.manager import InventoryManager
from ansible.vars.manager import VariableManager


def extract_proxy_jump(common_args: str) -> str | None:
    args = shlex.split(common_args)

    for i, arg in enumerate(args):
        if arg == "-J":
            return args[i + 1] if i + 1 < len(args) else None

        if arg.startswith("-J") and len(arg) > 2:
            return arg[2:]

        if arg.startswith("ProxyJump="):
            return arg.split("=", 1)[1]

    return None


def get_dropbear_port(vars_: dict) -> int | str:
    port = vars_.get("cryptroot_port")

    if port is None or port == "":
        return 2244

    return port


def print_ssh_host(
    name: str,
    hostname: str,
    port: int | str,
    user: str,
    proxy_jump: str | None,
) -> None:
    print(f"Host {name}")
    print(f"  HostName {hostname}")
    print(f"  Port {port}")
    print(f"  User {user}")

    if proxy_jump:
        print(f"  ProxyJump {proxy_jump}")

    print("  StrictHostKeyChecking no")
    print("  UserKnownHostsFile /dev/null")
    print("  GlobalKnownHostsFile /dev/null")
    print()


def main() -> int:
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} inventory.ini", file=sys.stderr)
        return 1

    inventory_file = sys.argv[1]

    loader = DataLoader()
    inventory = InventoryManager(loader=loader, sources=[inventory_file])
    variable_manager = VariableManager(loader=loader, inventory=inventory)

    for host in inventory.get_hosts():
        vars = variable_manager.get_vars(host=host)

        hostname = vars.get("ansible_host", host.name)
        port = vars.get("ansible_port", 22)
        user = vars.get("ansible_user", vars.get("ansible_ssh_user", "root"))
        common_args = vars.get("ansible_ssh_common_args", "")
        dropbear_port = get_dropbear_port(vars)
        proxy_jump = extract_proxy_jump(common_args)

        print_ssh_host(
            name=host.name,
            hostname=hostname,
            port=port,
            user=user,
            proxy_jump=proxy_jump,
        )

        print_ssh_host(
            name=f"{host.name}-dropbear",
            hostname=hostname,
            port=dropbear_port,
            user="root",
            proxy_jump=proxy_jump,
        )

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
